# Local direct-Node example. For Docker Compose, start from `.env.compose.example`
# so `DATABASE_URL` and `MEDIA_ROOT` point at the mounted container paths.
DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"
OWNER_USERNAME="owner"
OWNER_PASSWORD="replace-with-a-long-password"
# Optional mounted media root override. Docker Compose uses `/app/media`.
# MEDIA_ROOT="./media"
# Mina-hosted OpenAI-compatible endpoint for AI enrichment and `@ai-real` Playwright runs.
# Keep these values local only. Missing or partial config records a visible failed enrichment state instead of falling back silently.
LLM_BASE="https://mina-host.example/v1"
TOKEN="replace-with-a-mina-api-token"
MODEL="replace-with-a-mina-model-id"
MINA_AI_TIMEOUT_MS="15000"
LOG_LEVEL="info"
PORT="3000"
