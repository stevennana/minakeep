{
  "name": "minakeep",
  "version": "1.0.11",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:prepare": "node scripts/db-prepare.mjs",
    "test:unit": "NODE_PATH=./node_modules/next/dist/compiled node --conditions=react-server --import tsx --test tests/unit/**/*.test.ts",
    "test:e2e": "./scripts/ralph/ensure-e2e-port-free.sh ${PLAYWRIGHT_WEB_SERVER_PORT:-3210} && npm run db:prepare && playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "start:smoke": "node scripts/start-smoke.mjs",
    "start:logged": "node scripts/start-logged.mjs",
    "verify": "npm run lint && npm run db:prepare && npm run typecheck && npm run build && npm run test && npm run start:smoke",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.8.0",
    "katex": "^0.16.43",
    "mermaid": "^11.11.0",
    "next": "^16.2.0",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
