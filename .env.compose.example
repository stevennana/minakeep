# Compose keeps SQLite at `/app/data/minakeep.db` and media at `/app/media`
# through `docker-compose.yml`; this file is for auth, port, logging, and AI config.
# Schema-changing upgrades create timestamped SQLite backups under `/app/data/backups`.
AUTH_SECRET="replace-with-a-long-random-secret"
OWNER_USERNAME="owner"
OWNER_PASSWORD="replace-with-a-long-password"
# Optional demonstration credentials. Set both or leave both unset.
# DEMO_USERNAME must differ from OWNER_USERNAME.
# Demo auth stays env-backed and read-only; only the owner password hash is stored in SQLite.
# DEMO_USERNAME="demo"
# DEMO_PASSWORD="replace-with-a-long-demo-password"
# Optional server-to-server external note-create API.
# This wave uses only one static `API_KEY` sent through `X-API-Key`; leave it unset to keep `/api/open/notes` disabled.
# Requests accept `title`, `markdown`, and optional `isPublished=true`; omitted publish state keeps created notes private.
# API_KEY="replace-with-a-long-random-static-key"
LOG_LEVEL="info"
PORT="3000"
# Optional AI enrichment. Uncomment only when a real Mina endpoint is configured.
# LLM_BASE="https://mina-host.example/v1"
# TOKEN="replace-with-a-mina-api-token"
# MODEL="replace-with-a-mina-model-id"
# MINA_AI_TIMEOUT_MS="15000"
