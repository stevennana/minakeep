generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  notes        Note[]
  links        Link[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Note {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  slug        String   @unique
  markdown    String
  excerpt     String
  summary     String?
  enrichmentStatus    String   @default("pending")
  enrichmentError     String?
  enrichmentAttempts  Int      @default(0)
  enrichmentUpdatedAt DateTime?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  tags        Tag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Link {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  url       String
  title     String
  summary   String
  enrichmentStatus    String   @default("pending")
  enrichmentError     String?
  enrichmentAttempts  Int      @default(0)
  enrichmentUpdatedAt DateTime?
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, url])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  notes     Note[]
  links     Link[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
